/* ═══════════════════════════════════════════
   Claude Code for Unity — Unity Default Theme
   ═══════════════════════════════════════════ */

.root { flex-grow: 1; background-color: #383838; }

/* ── Toolbar ── */
.toolbar { flex-direction: row; align-items: center; padding: 4px 8px; background-color: #3C3C3C; border-bottom-width: 1px; border-bottom-color: #232323; min-height: 28px; flex-shrink: 0; }
.toolbar-title { color: #4C7EFF; font-size: 13px; -unity-font-style: bold; }
.toolbar-btn { background-color: #585858; color: #D4D4D4; border-width: 1px; border-color: #303030; border-radius: 3px; padding: 2px 10px; font-size: 11px; }
.toolbar-btn:hover { background-color: #676767; }

/* ── Output area ── */
.output-scroll { flex-grow: 1; background-color: #383838; }
.output-scroll #unity-content-container { padding: 8px 12px; }

/* ── Message blocks ── */
.message-block { margin-bottom: 6px; }
.message-content { white-space: normal; font-size: 13px; padding: 2px 0; }

.user-message .message-content { color: #8DC14F; -unity-font-style: bold; }
.system-message .message-content { color: #707070; -unity-font-style: italic; font-size: 12px; }
.result-message .message-content { color: #8DC14F; font-size: 11px; }

/* ── Message group (one assistant turn) ── */
.message-group { padding-left: 8px; border-left-width: 2px; border-left-color: #4C7EFF; margin-bottom: 8px; }

/* Claude message (history replay) */
.claude-message { padding-left: 8px; border-left-width: 2px; border-left-color: #4C7EFF; margin-bottom: 8px; }

/* ── Thinking indicator (animated) ── */
.thinking-indicator { color: #9A9A9A; font-size: 12px; -unity-font-style: italic; padding: 4px 0; margin-bottom: 4px; }

/* ── Thinking ── */
.thinking-container { margin-bottom: 4px; }
.thinking-item { color: #707070; font-size: 11px; white-space: normal; padding: 2px 0 2px 8px; border-left-width: 2px; border-left-color: #555555; margin-bottom: 2px; }
.thinking-active { color: #9A9A9A; border-left-color: #F0A030; }
.thinking-foldout { margin-bottom: 4px; }
.thinking-foldout > .unity-foldout__toggle > .unity-foldout__text { color: #707070; font-size: 11px; -unity-font-style: italic; }

/* ── Tools foldout ── */
.tools-foldout { margin-bottom: 6px; }
.tools-foldout > .unity-foldout__toggle > .unity-foldout__text { color: #4C7EFF; font-size: 11px; }
.tool-item { color: #707070; font-size: 11px; white-space: normal; padding-left: 4px; margin-bottom: 1px; }

/* ── Group content ── */
.group-content { }
.streaming-text { white-space: normal; font-size: 13px; color: #D4D4D4; }

/* ── Group result ── */
.group-result { color: #8DC14F; font-size: 11px; margin-top: 6px; }

/* ── Action buttons ── */
.actions-container { flex-direction: row; flex-wrap: wrap; margin-top: 8px; }
.action-btn { background-color: #585858; color: #D4D4D4; border-width: 1px; border-color: #303030; border-radius: 4px; padding: 4px 14px; font-size: 11px; margin-right: 6px; margin-bottom: 4px; }
.action-btn:hover { background-color: #676767; border-color: #4C7EFF; color: #4C7EFF; }

/* ═══════════════════════════════════════════
   Markdown rendering
   ═══════════════════════════════════════════ */

.md-container { }

/* Paragraphs */
.md-paragraph { white-space: normal; font-size: 13px; color: #D4D4D4; margin-bottom: 6px; }

/* Headers */
.md-header { color: #4C7EFF; margin-top: 10px; margin-bottom: 4px; -unity-font-style: bold; }
.md-h1 { font-size: 20px; }
.md-h2 { font-size: 17px; }
.md-h3 { font-size: 15px; }
.md-h4 { font-size: 13px; }
.md-h5 { font-size: 12px; }
.md-h6 { font-size: 11px; }

/* Code blocks */
.md-code-block { background-color: #222222; border-radius: 4px; padding: 8px; margin-top: 4px; margin-bottom: 6px; border-width: 1px; border-color: #303030; }
.md-code-header { flex-direction: row; align-items: center; margin-bottom: 4px; }
.md-code-lang { color: #707070; font-size: 10px; }
.md-code-copy { background-color: #585858; color: #707070; border-width: 1px; border-color: #303030; border-radius: 3px; padding: 1px 8px; font-size: 10px; }
.md-code-copy:hover { color: #D4D4D4; background-color: #676767; }
.md-code-text { font-size: 12px; color: #D4D4D4; white-space: normal; -unity-font-style: normal; }

/* Lists */
.md-list { margin-top: 2px; margin-bottom: 6px; }
.md-list-item { flex-direction: row; margin-bottom: 2px; }
.md-bullet { color: #4C7EFF; width: 20px; flex-shrink: 0; font-size: 13px; -unity-text-align: upper-right; padding-right: 6px; }
.md-list-text { white-space: normal; font-size: 13px; color: #D4D4D4; flex-shrink: 1; flex-grow: 1; }

/* Tables */
.md-table { margin-top: 4px; margin-bottom: 6px; border-width: 1px; border-color: #303030; border-radius: 4px; overflow: hidden; }
.md-table-row { flex-direction: row; border-bottom-width: 1px; border-bottom-color: #303030; }
.md-table-header { background-color: #3C3C3C; }
.md-table-cell { padding: 3px 10px; min-width: 60px; font-size: 12px; color: #D4D4D4; white-space: normal; flex: 1; border-right-width: 1px; border-right-color: #303030; }
.md-table-cell-header { -unity-font-style: bold; color: #4C7EFF; }

/* Blockquotes */
.md-blockquote { border-left-width: 3px; border-left-color: #555555; padding-left: 10px; margin-top: 4px; margin-bottom: 6px; }
.md-blockquote .md-paragraph { color: #B0B0B0; -unity-font-style: italic; }

/* Horizontal rule */
.md-hr { height: 1px; background-color: #303030; margin-top: 8px; margin-bottom: 8px; }

/* ═══════════════════════════════════════════
   Reply bar
   ═══════════════════════════════════════════ */

.reply-container { background-color: #3C3C3C; padding: 4px 8px; border-top-width: 1px; border-top-color: #D32F2F; flex-shrink: 0; }
.reply-row { flex-direction: row; align-items: center; }
.reply-label { color: #D32F2F; font-size: 11px; -unity-font-style: bold; margin-right: 6px; flex-shrink: 0; }
.reply-field { flex-grow: 1; margin-right: 6px; }
.reply-field #unity-text-input { background-color: #2A2A2A; color: #D4D4D4; border-color: #D32F2F; border-width: 1px; border-radius: 3px; padding: 3px 6px; font-size: 12px; }
.reply-btn { background-color: #D32F2F; color: #FFFFFF; border-width: 0; border-radius: 3px; padding: 3px 12px; font-size: 11px; -unity-font-style: bold; }
.reply-btn:hover { background-color: #E05050; }

/* ═══════════════════════════════════════════
   Input area
   ═══════════════════════════════════════════ */

.input-container { background-color: #3C3C3C; padding: 8px; border-top-width: 1px; border-top-color: #232323; flex-shrink: 0; }
.input-row { flex-direction: row; align-items: flex-end; }
.input-field { flex-grow: 1; flex-shrink: 1; margin-right: 6px; overflow: hidden; }
.input-field #unity-text-input { background-color: #2A2A2A; color: #D4D4D4; border-width: 1px; border-color: #303030; border-radius: 4px; padding: 5px 8px; font-size: 13px; min-height: 36px; max-height: 120px; white-space: normal; }
.input-field:focus #unity-text-input { border-color: #4C7EFF; }

.btn-container { flex-direction: row; flex-shrink: 0; }
.send-btn { background-color: #4C7EFF; color: #FFFFFF; border-width: 0; border-radius: 4px; padding: 5px 16px; font-size: 12px; -unity-font-style: bold; min-height: 26px; }
.send-btn:hover { background-color: #6B93FF; }
.cancel-btn { background-color: #F0A030; color: #1E1E1E; border-width: 0; border-radius: 4px; padding: 5px 14px; font-size: 12px; -unity-font-style: bold; min-height: 26px; }
.cancel-btn:hover { background-color: #FFB84D; }

/* ── Options ── */
.options-row { flex-direction: row; align-items: center; margin-top: 6px; flex-wrap: wrap; }

/* Toggle pills — checkbox tight against label */
.option-toggle { flex-direction: row; align-items: center; margin-right: 4px; padding: 2px 8px 2px 4px; background-color: #585858; border-radius: 10px; border-width: 1px; border-color: #303030; }
.option-toggle:hover { border-color: #707070; }
.option-toggle .unity-toggle__input { flex-direction: row; align-items: center; }
.option-toggle .unity-toggle__checkmark { width: 12px; height: 12px; margin-right: 4px; border-radius: 3px; background-color: #303030; border-width: 1px; border-color: #555555; }
.option-toggle:checked .unity-toggle__checkmark { background-color: #8DC14F; border-color: #8DC14F; }
.option-toggle Label { color: #9A9A9A; font-size: 11px; padding: 0; margin: 0; }
.option-toggle:checked Label { color: #8DC14F; }

/* Model dropdown pill */
.model-dropdown { margin-right: 4px; }
.model-dropdown .unity-popup-field__input { background-color: #585858; border-color: #303030; border-radius: 10px; color: #D4D4D4; font-size: 11px; min-height: 20px; padding: 1px 8px; }
.model-dropdown .unity-popup-field__input:hover { border-color: #707070; }
.model-dropdown .unity-popup-field__label { display: none; }

/* Max turns pill */
.max-turns-group { flex-direction: row; align-items: center; background-color: #585858; border-radius: 10px; border-width: 1px; border-color: #303030; padding: 1px 8px 1px 8px; margin-right: 4px; }
.max-turns-label { color: #9A9A9A; font-size: 11px; margin-right: 4px; min-width: 46px; padding: 0; }
.max-turns-slider { width: 50px; }
.max-turns-slider .unity-base-slider__dragger { background-color: #4C7EFF; border-radius: 5px; height: 10px; width: 10px; margin-top: -4px; }
.max-turns-slider .unity-base-slider__tracker { background-color: #303030; height: 3px; border-radius: 2px; }

/* ── Status ── */
.status-row { flex-direction: row; align-items: center; margin-top: 4px; }
.status-label { color: #9A9A9A; font-size: 11px; padding-left: 2px; flex-shrink: 0; }
.usage-label { color: #8DC14F; font-size: 11px; margin-left: auto; -unity-text-align: middle-right; }

/* ── Agent chips ── */
.agent-chips { flex-direction: row; flex-wrap: wrap; margin-top: 4px; margin-bottom: 2px; }
.agent-chip { flex-direction: row; align-items: center; border-radius: 10px; padding: 2px 4px 2px 8px; margin-right: 4px; margin-bottom: 3px; border-width: 1px; }
.agent-chip--active { background-color: rgba(76, 126, 255, 0.15); border-color: #4C7EFF; }
.agent-chip--active .agent-chip-label { color: #4C7EFF; }
.agent-chip--inactive { background-color: #585858; border-color: #303030; color: #9A9A9A; font-size: 11px; padding: 2px 8px; border-radius: 10px; }
.agent-chip--inactive:hover { border-color: #4C7EFF; color: #4C7EFF; }
.agent-chip-label { color: #4C7EFF; font-size: 11px; margin-right: 2px; }
.agent-chip-remove { background-color: transparent; color: #707070; border-width: 0; padding: 0 4px; font-size: 12px; min-width: 16px; min-height: 16px; -unity-text-align: middle-center; }
.agent-chip-remove:hover { color: #D32F2F; }

/* ── Attachment chips ── */
.attachment-chips { flex-direction: row; flex-wrap: wrap; margin-top: 4px; margin-bottom: 2px; }
.attachment-chip { flex-direction: row; align-items: center; background-color: #585858; border-radius: 10px; padding: 2px 4px 2px 8px; margin-right: 4px; margin-bottom: 3px; border-width: 1px; border-color: #303030; }
.attachment-chip-label { color: #4C7EFF; font-size: 11px; margin-right: 2px; }
.attachment-chip-remove { background-color: transparent; color: #707070; border-width: 0; padding: 0 4px; font-size: 12px; min-width: 16px; min-height: 16px; -unity-text-align: middle-center; }
.attachment-chip-remove:hover { color: #D32F2F; }

/* ── Drag-and-drop ── */
.drop-hover { border-width: 2px; border-color: #4C7EFF; border-radius: 6px; background-color: rgba(76, 126, 255, 0.08); }
.drop-hover .input-field #unity-text-input { border-color: #4C7EFF; }

/* ── File import window ── */
.import-root { flex-grow: 1; background-color: #383838; }
.import-toolbar { flex-direction: row; align-items: center; padding: 4px 8px; background-color: #3C3C3C; border-bottom-width: 1px; border-bottom-color: #232323; }
.import-path-field { flex-grow: 1; margin-right: 4px; }
.import-path-field #unity-text-input { background-color: #2A2A2A; color: #D4D4D4; border-color: #303030; border-radius: 3px; padding: 2px 6px; font-size: 11px; }
.import-browse-btn { background-color: #585858; color: #D4D4D4; border-width: 1px; border-color: #303030; border-radius: 3px; padding: 2px 8px; font-size: 11px; min-width: 24px; }
.import-browse-btn:hover { background-color: #676767; }
.import-filter-row { flex-direction: row; align-items: center; padding: 4px 8px; background-color: #3C3C3C; border-bottom-width: 1px; border-bottom-color: #232323; }
.import-filter-field { flex-grow: 1; margin-right: 4px; }
.import-filter-field #unity-text-input { background-color: #2A2A2A; color: #D4D4D4; border-color: #303030; border-radius: 3px; padding: 2px 6px; font-size: 11px; }
.import-file-list { flex-grow: 1; background-color: #383838; }
.import-file-list #unity-content-container { padding: 2px 4px; }
.import-file-item { flex-direction: row; align-items: center; padding: 2px 4px; border-radius: 2px; }
.import-file-item:hover { background-color: #454545; }
.import-file-toggle .unity-toggle__checkmark { width: 14px; height: 14px; border-radius: 2px; background-color: #303030; border-width: 1px; border-color: #555555; }
.import-file-toggle:checked .unity-toggle__checkmark { background-color: #4C7EFF; border-color: #4C7EFF; }
.import-file-label { color: #D4D4D4; font-size: 11px; margin-left: 4px; }
.import-file-dir { color: #707070; font-size: 10px; margin-left: 4px; }
.import-footer { flex-direction: row; align-items: center; justify-content: flex-end; padding: 6px 8px; background-color: #3C3C3C; border-top-width: 1px; border-top-color: #232323; }
.import-select-btn { background-color: #585858; color: #D4D4D4; border-width: 1px; border-color: #303030; border-radius: 3px; padding: 3px 10px; font-size: 11px; margin-right: 4px; }
.import-select-btn:hover { background-color: #676767; }
.import-attach-btn { background-color: #4C7EFF; color: #FFFFFF; border-width: 0; border-radius: 3px; padding: 3px 14px; font-size: 11px; -unity-font-style: bold; }
.import-attach-btn:hover { background-color: #6B93FF; }
