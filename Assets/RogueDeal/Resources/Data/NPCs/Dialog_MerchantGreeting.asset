      condition:
        conditionType: 0
        questId: 
        requiredQuestStatus: 0
        itemId: 
        requiredItemAmount: 0
      actions: []
    actions: []
    nextNodeId: 
    isEndNode: 0
    editorPosition: {x: 0, y: 0}
  - nodeId: quest_ask
    displayName: Quest Ask
    speaker: Merchant
    text: Actually, yes! I need someone to collect 5 wolf pelts for me. The wolves
      have been attacking my supply caravans. Can you help?
    speakerPortrait: {fileID: 0}
    choices:
    - text: Sure, I'll help you out!
      nextNodeId: quest_accept
      condition:
        conditionType: 0
        questId: 
        requiredQuestStatus: 0
        itemId: 
        requiredItemAmount: 0
      actions:
      - actionType: 0
        questId: 
        itemId: 
        itemAmount: 0
        goldAmount: 0
        targetDialogTree: {fileID: 0}
        closeBeforeSwitch: 0
    - text: Not right now, sorry.
      nextNodeId: quest_decline
      condition:
        conditionType: 0
        questId: 
        requiredQuestStatus: 0
        itemId: 
        requiredItemAmount: 0
      actions: []
    actions: []
    nextNodeId: 
    isEndNode: 0
    editorPosition: {x: 0, y: 0}
  - nodeId: quest_accept
    displayName: Quest Accept
    speaker: Merchant
    text: Excellent! I'll mark the wolf den on your map. Good luck, and be careful!
    speakerPortrait: {fileID: 0}
    choices: []
    actions:
    - actionType: 1
      questId: test_quest
      itemId: 
      itemAmount: 0
      goldAmount: 0
      targetDialogTree: {fileID: 0}
      closeBeforeSwitch: 0
