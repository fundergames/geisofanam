  dialogId: merchant_greeting
  displayName: Merchant Greeting
  nodes:
  - nodeId: greeting
    displayName: Greeting
    speaker: Merchant
    text: Hello traveler! Welcome to my shop. What can I do for you today?
    speakerPortrait: {fileID: 0}
    choices:
    - text: Do you have any quests for me?
      nextNodeId: quest_ask
      condition:
        conditionType: 0
        questId: 
        requiredQuestStatus: 0
        itemId: 
        requiredItemAmount: 0
      actions: []
    - text: Just browsing, thanks.
